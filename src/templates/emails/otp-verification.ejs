<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Verify your account - Consultly</title>
    <style>
      body {
        margin: 0;
        padding: 0;
        background-color: #f4f5f7;
        font-family: 'Inter', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      }
      .container {
        max-width: 600px;
        margin: 40px auto;
        background-color: #fcfcfc;
        border-radius: 16px;
        overflow: hidden;
        padding: 40px 30px;
        text-align: center;
      }
      .logo {
        margin-bottom: 40px;
      }
      .logo-text {
        font-size: 20px;
        font-weight: 700;
        color: #004d61;
        display: inline-block;
        vertical-align: middle;
        margin-left: 8px;
        letter-spacing: -0.5px;
      }
      h1 {
        font-size: 28px;
        color: #111;
        margin: 0 0 15px;
        letter-spacing: -0.5px;
      }
      p.subtitle {
        color: #666;
        font-size: 16px;
        line-height: 1.6;
        margin: 0 auto 30px;
        max-width: 350px;
      }
      .otp-box {
        background-color: #ffffff;
        border-radius: 12px;
        padding: 30px 20px;
        margin-bottom: 25px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.03);
      }
      .otp-code {
        font-family: 'Courier New', monospace;
        font-size: 42px;
        font-weight: 700;
        color: #004d61;
        letter-spacing: 16px;
        margin-left: 16px; /* offset for letter-spacing */
      }
      .expiry-pill {
        display: inline-block;
        background-color: #f0f0f0;
        color: #666;
        font-size: 13px;
        border-radius: 20px;
        padding: 10px 20px;
        margin-bottom: 40px;
      }
      .info-text {
        font-style: italic;
        color: #888;
        font-size: 13px;
        line-height: 1.6;
        max-width: 360px;
        margin: 0 auto 40px;
      }
      .footer {
        color: #999999;
        font-size: 12px;
        padding-top: 20px;
      }
      .footer a {
        color: #004d61;
        text-decoration: none;
        margin: 0 10px;
      }
      .footer-links {
        margin: 15px 0 20px;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="logo">
        <span style="color: #004d61; font-size: 24px;">✦</span>
        <div class="logo-text">Consultly</div>
      </div>
      
      <h1>Verify your account</h1>
      <p class="subtitle">
        Use the code below to complete your sign-in.
      </p>
      
      <div class="otp-box">
        <div class="otp-code"><%= otp %></div>
      </div>
      
      <div class="expiry-pill">
        🕒 This code expires in <%= expiresInMinutes %> minutes.
      </div>
      
      <div class="info-text">
        If you didn't request this code, please ignore this email. Your account remains secure.
      </div>
      
      <div class="footer">
        <div class="footer-links">
          <a href="#">Privacy Policy</a>
          <a href="#">Unsubscribe</a>
        </div>
        <p>&copy; <%= new Date().getFullYear() %> Consultly. All rights reserved.</p>
      </div>
    </div>
  </body>
</html>
