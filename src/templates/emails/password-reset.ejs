<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset your password - Consultly</title>
    <style>
      body {
        margin: 0;
        padding: 0;
        background-color: #f4f5f7;
        font-family: 'Inter', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      }
      .container {
        max-width: 600px;
        margin: 40px auto;
        background-color: #fcfcfc;
        border-radius: 16px;
        overflow: hidden;
        padding: 40px 30px;
        text-align: center;
      }
      .logo {
        margin-bottom: 40px;
      }
      .logo-text {
        font-size: 20px;
        font-weight: 700;
        color: #004d61;
        display: inline-block;
        vertical-align: middle;
        margin-left: 8px;
        letter-spacing: -0.5px;
      }
      .icon-circle {
        width: 60px;
        height: 60px;
        background-color: #e6eef0;
        border-radius: 50%;
        margin: 0 auto 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        color: #004d61;
        line-height: 60px;
      }
      h1 {
        font-size: 28px;
        color: #111;
        margin: 0 0 15px;
        letter-spacing: -0.5px;
      }
      p.subtitle {
        color: #666;
        font-size: 15px;
        line-height: 1.6;
        margin: 0 auto 30px;
        max-width: 400px;
      }
      .action-box {
        background-color: #ffffff;
        border-radius: 12px;
        padding: 40px 30px;
        margin-bottom: 30px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.03);
      }
      .button {
        display: inline-block;
        padding: 16px 0;
        width: 100%;
        background-color: #004d61;
        color: #ffffff;
        text-decoration: none;
        border-radius: 8px;
        font-weight: 600;
        font-size: 16px;
      }
      .expiry {
        margin-top: 25px;
        font-size: 13px;
        color: #888;
        font-weight: 500;
      }
      .expiry span {
        color: #8d5d30;
        margin-right: 5px;
      }
      .security-box {
        background-color: #f5f5f5;
        border-radius: 12px;
        padding: 20px;
        text-align: left;
        display: table;
        width: 100%;
        box-sizing: border-box;
      }
      .sec-icon {
        display: table-cell;
        width: 44px;
        vertical-align: top;
      }
      .sec-icon div {
        background: #e6eef0;
        width: 32px;
        height: 32px;
        border-radius: 6px;
        text-align: center;
        line-height: 32px;
        color: #004d61;
        font-size: 16px;
      }
      .sec-text {
        display: table-cell;
        vertical-align: top;
      }
      .sec-text h4 {
        margin: 0 0 5px 0;
        font-size: 13px;
        color: #333;
        text-transform: uppercase;
        letter-spacing: 1px;
      }
      .sec-text p {
        margin: 0;
        font-size: 13px;
        color: #666;
        line-height: 1.5;
      }
      .footer {
        color: #999999;
        font-size: 12px;
        margin-top: 40px;
      }
      .footer a {
        color: #004d61;
        text-decoration: none;
        margin: 0 10px;
      }
      .footer-links {
        margin: 15px 0;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="logo">
        <span style="color: #004d61; font-size: 24px;">✦</span>
        <div class="logo-text">Consultly</div>
      </div>
      
      <div class="icon-circle">
        ↻
      </div>
      
      <h1>Reset your password</h1>
      <p class="subtitle">
        We received a request to reset your password. If you didn't make this request, ignore this email.
      </p>
      
      <div class="action-box">
        <a href="<%= resetLink %>" class="button">Reset Password</a>
        <div class="expiry">
          <span>🕒</span> This link expires in <%= expiresIn %> minutes.
        </div>
      </div>
      
      <div class="security-box">
        <div class="sec-icon">
          <div>🛡️</div>
        </div>
        <div class="sec-text">
          <h4>Secure Access</h4>
          <p>Your security is our priority. This reset link is unique to your account and should not be shared with anyone.</p>
        </div>
      </div>
      
      <div class="footer">
        <div style="margin-top: 20px; margin-bottom: 20px; letter-spacing: 8px; opacity: 0.3; font-size: 24px;">
          •••
        </div>
        <p>&copy; <%= new Date().getFullYear() %> Consultly. All rights reserved.</p>
        <div class="footer-links">
          <a href="#">Privacy Policy</a>
          <a href="#">Unsubscribe</a>
        </div>
      </div>
    </div>
  </body>
</html>
